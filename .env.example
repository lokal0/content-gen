# Database (Neon Postgres recommended — auto-converts postgresql:// to postgresql+asyncpg://)
DATABASE_URL=postgresql://user:password@host:5432/content_gen

# Tavily — site crawling + agent web search (https://tavily.com)
TAVILY_API_KEY=tvly-xxxxx

# Google Gemini — keyword/article embeddings (https://ai.google.dev)
GEMINI_API_KEY=AIza-xxxxx

# Anthropic — Claude content agent (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Pioneer (Fastino) — GLiNER2 intent classification + fine-tuning (https://pioneer.ai)
PIONEER_API_KEY=pio_sk_xxxxx

# SEO API — internal DataForSEO proxy (run seo-api locally or point to deployed instance)
SEO_API_URL=http://localhost:3000
SEO_API_TOKEN=

# API auth — set to protect endpoints (optional for local dev)
API_BEARER_TOKEN=
