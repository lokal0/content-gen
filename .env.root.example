# === Lokal — Environment Variables ===

# DataForSEO (via seo-api) — base64 of "login:password"
# Generate: printf '%s' 'YOUR_LOGIN:YOUR_PASSWORD' | base64
DATAFORSEO_API_KEY=

# Postgres (Neon recommended) — for content-gen backend
DATABASE_URL=postgresql://user:password@host:5432/content_gen

# Postgres — for lokal-next frontend (can be same or different DB)
LOKAL_DATABASE_URL=postgresql://user:password@host:5432/neondb

# Tavily — site crawling + agent web search
# Sign up: https://tavily.com
TAVILY_API_KEY=tvly-xxxxx

# Google Gemini — keyword/article embeddings
# Get key: https://ai.google.dev
GEMINI_API_KEY=AIza-xxxxx

# Anthropic — Claude content agent
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Pioneer (Fastino) — GLiNER2 intent classification + fine-tuning
# Get key: https://pioneer.ai
PIONEER_API_KEY=pio_sk_xxxxx

# Google Places — business extraction from Maps URLs
# Get key: https://console.cloud.google.com
GOOGLE_PLACES_API_KEY=AIza-xxxxx

# Clerk — authentication (for frontend only)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_xxxxx
CLERK_SECRET_KEY=sk_xxxxx
